# --- Used by the app directly (and by docker-compose.dev.yml) ---

# Long random string used to sign tokens. Generate e.g. `openssl rand -hex 32`.
PAYLOAD_SECRET=change-me

# Postgres connection string.
DATABASE_URI=postgres://postgres:postgres@postgres:5432/payload

# Public URL of the CMS (https://payload.tzhk.dev). On Coolify this is filled
# automatically from SERVICE_URL_PAYLOAD (full URL with scheme) — leave blank locally.
PAYLOAD_PUBLIC_SERVER_URL=

# Comma-separated frontend origins allowed to call the API.
# e.g. https://tzhk.dev,https://www.tzhk.dev
CORS_ORIGINS=

# --- Optional overrides for the production docker-compose.yml ---
# On Coolify these are auto-generated; only set them to override.
# POSTGRES_DB=payload
# SERVICE_USER_POSTGRES=
# SERVICE_PASSWORD_POSTGRES=
# SERVICE_BASE64_64_PAYLOADSECRET=
