# Long random string used to sign tokens. Generate e.g. `openssl rand -hex 32`.
PAYLOAD_SECRET=change-me

# Postgres connection string.
# Local docker-compose:  postgres://postgres:postgres@postgres:5432/tzhk
# Coolify:               postgres://<user>:<pass>@<db-host>:5432/<db>
DATABASE_URI=postgres://postgres:postgres@postgres:5432/tzhk
