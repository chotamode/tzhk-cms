# --- Used by the app directly (and by docker-compose.dev.yml) ---

# Long random string used to sign tokens. Generate e.g. `openssl rand -hex 32`.
PAYLOAD_SECRET=change-me

# Postgres connection string.
DATABASE_URI=postgres://postgres:postgres@postgres:5432/payload

# Public URL of the CMS (https://payload.tzhk.dev). On Coolify this is filled
# automatically from SERVICE_URL_PAYLOAD (full URL with scheme) — leave blank locally.
PAYLOAD_PUBLIC_SERVER_URL=

# Comma-separated frontend origins allowed to call the API.
# e.g. https://tzhk.dev,https://www.tzhk.dev
CORS_ORIGINS=

# Auto-sync the DB schema on boot (creates/updates tables). Defaults to on.
# Set to "false" only once you adopt a proper migration workflow.
PAYLOAD_DB_PUSH=

# --- Object storage for uploads (Cloudflare R2 / any S3-compatible) ---
# Leave blank locally to store uploads on the local disk. In production set all
# of these so media survives redeploys.
# For Cloudflare R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#                    S3_REGION=auto, bucket = your R2 bucket name.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public base URL for the bucket above (its r2.dev domain, or a custom domain
# mapped to it). When set, media URLs point straight at it instead of being
# proxied through this server's /api/media/file/* route — reads then come
# from the CDN edge instead of an origin round-trip on every image.
# e.g. https://pub-xxxxxxxx.r2.dev
S3_PUBLIC_URL=

# --- Email (SMTP) ---
# Any SMTP server works (managed service or your own). Leave SMTP_HOST blank to
# just log emails to the console (local dev). SMTP_SECURE=true only for port 465.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@tzhk.dev
EMAIL_FROM_NAME=TZHK

# --- Optional overrides for the production docker-compose.yml ---
# On Coolify these are auto-generated; only set them to override.
# POSTGRES_DB=payload
# SERVICE_USER_POSTGRES=
# SERVICE_PASSWORD_POSTGRES=
# SERVICE_BASE64_64_PAYLOADSECRET=
